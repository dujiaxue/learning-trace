# ─── DeepSeek API ───
# 在 https://platform.deepseek.com/ 申请
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ─── Database ───
# 生产用 PostgreSQL（推荐 Neon / Supabase / Vercel Postgres）
# 本地开发也可指向本地 Postgres：postgresql://user:pass@localhost:5432/learning_trace?schema=public
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ─── NextAuth ───
# 生成：openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# ─── Vercel Blob Storage（PDF 存储） ───
# 在 Vercel 项目 → Storage → 创建 Blob Store → 复制 BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here
