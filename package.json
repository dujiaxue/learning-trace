    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.44.0",
    "pdfjs-dist": "^6.0.227",
    "prisma": "^6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
